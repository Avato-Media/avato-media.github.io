    <script defer>
        let sideNavStatus = 'hide';
        let childNodesSet = false;
        
        let triggerBtn;
        let sideNav;
        let preloader;
        let mainContent;
        
        window.onload = () => {
            // Get All Elements
            preloader = document.querySelector("#preloader");
            mainContent = document.querySelector("#main-wrapper");

            setTimeout(() => {
                preloader.classList.toggle("loader-hide");
                mainContent.classList.toggle("content-show");
            }, 5000)
            // Do Events
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Get all Elements
            triggerBtn = document.querySelector(".sidenav-trigger");

            // Add Event Listeners
            triggerBtn.addEventListener('click', (event) => {
                event.preventDefault();
                toggleSideNav();
            })
        });

        function toggleSideNav(toggle) {
            if(!childNodesSet){
                
                sideNav = document.querySelector("#".concat(triggerBtn.getAttribute("data-target")));
                sideNav.childNodes.forEach((node) => {
                    if(node.nodeName === "LI") {
                        node.addEventListener('click', (event) => {
                            event.preventDefault();
                            toggleSideNav('hide');

                            if(event.target.nodeName != "A"){
                                location.href = event.target.parentNode.href;
                            } else {
                                location.href = event.target.href;
                            }
                        })
                    }
                });
                childNodesSet = true;
            }

            switch(toggle) {
                case 'show':
                    sideNav.setAttribute("style", "transform: translateX(0%); transition: transform 0.55s ease-in-out;");
                    sideNavStatus = 'show';
                    break;
                case 'hide':
                    sideNav.setAttribute("style", "transform: translateX(-105%);  transition: transform 0.55s ease-in-out;");
                    sideNavStatus = 'hide';
                    break;
                default:
                    switch (sideNavStatus) {
                        case 'hide':
                            sideNav.setAttribute("style", "transform: translateX(0%);  transition: transform 0.55s ease-in-out;");
                            sideNavStatus = 'show';
                            break;
                        case 'show':
                            sideNav.setAttribute("style", "transform: translateX(-105%);  transition: transform 0.55s ease-in-out;");
                            sideNavStatus = 'hide';
                            break;
                        default:
                            sideNav.setAttribute("style", "transform: translateX(-105%);  transition: transform 0.55s ease-in-out;");
                            sideNavStatus = 'hide';
                            break;
                    }
                    break;
            }
        }
    </script>
    <style>
        .loader-hide {
            opacity: 0%;
            transition: all 1.5s ease-out;
        }
        #main-wrapper {
            opacity: 0%;
            transition: all 1.5s ease-in;
        }
        .content-show {
            opacity: 100% !important;
            transition: all 1.5s ease-in !important;
        }

